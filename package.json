{
    "name": "timecard-plugin",
    "version": "1.0.0",
    "description": "Stream Deck plugin affichant l'heure locale de différents pays",
    "author": "Laxe4k",
    "scripts": {
        "build": "rollup -c && node scripts/native-modules.js",
        "build:prod": "npm run clean && set NODE_ENV=production&& rollup -c && node scripts/native-modules.js",
        "clean": "node scripts/clean.js",
        "package": "npm run build:prod && node scripts/package.js",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.laxe4k.timecard-plugin\"",
        "diagnostic": "node scripts/diagnostic.js",
        "update": "node scripts/update-plugin.js",
        "dev:update": "npm run build && npm run update",
        "verify:package": "node scripts/verify-package.js",
        "format": "prettier --write --experimental-cli src/"
    },
    "type": "module",
    "devDependencies": {
        "@elgato/cli": "^1.4.0",
        "@rollup/plugin-commonjs": "^28.0.6",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.1.4",
        "@tsconfig/node20": "^20.1.6",
        "@types/node": "~24.0.10",
        "rollup": "^4.60.0",
        "tslib": "^2.8.1",
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "@elgato/streamdeck": "^1.3.1",
        "@napi-rs/canvas": "^0.1.97"
    }
}